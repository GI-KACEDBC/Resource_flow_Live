APP_NAME=ResourceFlow
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

# Frontend URL - Used for Paystack callback, CORS, and Sanctum
# Must match your deployed frontend domain (no trailing slash)
FRONTEND_URL=https://yourdomain.com

# Sanctum - Add production domain for SPA cookie auth (comma-separated if multiple)
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,www.yourdomain.com,localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

# CORS - Optional: comma-separated origins if different from FRONTEND_URL
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Frontend build (Vite): use same-origin API in production when app and API share a host, e.g. VITE_API_BASE_URL=/api

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Database - PostgreSQL recommended for production
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=resourceflow
DB_USERNAME=
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# log = no SMTP. Real SMTP: set MAIL_MAILER=smtp and host/port. Mailpit on host: 127.0.0.1:1025. Docker Compose service name: mailpit:1025
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Signup OTP: SMS. driver=log (dev only) | twilio | http | arkesel (Arkesel generates/verifies OTP via API)
SMS_DRIVER=log
# SMS_HTTP_URL=
# SMS_HTTP_BEARER_TOKEN=
# TWILIO_SID=
# TWILIO_TOKEN=
# TWILIO_FROM=
# Arkesel OTP — https://developers.arkesel.com/#tag/One-Time-Password-(OTP) (use Main API key from dashboard)
# ARKESEL_API_KEY=
# ARKESEL_BASE_URL=https://sms.arkesel.com/api
# ARKESEL_SENDER_ID=Resource
# Must include %otp_code%; optional %expiry% — see Arkesel docs
# ARKESEL_OTP_MESSAGE="Your ResourceFlow verification code is %otp_code%. Expires in %expiry% minutes."

# Local E2E / manual QA only: fixed OTP when APP_ENV=local. Leave empty in production.
# REGISTRATION_E2E_OTP=

# Paystack - Use live keys for production
# Get keys from https://dashboard.paystack.com
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# QoreID - Ghana Card verification (use live keys for production)
# Get keys from https://dashboard.qoreid.com
QOREID_CLIENT_ID=your_qoreid_client_id
QOREID_SECRET=your_qoreid_secret
# For Ghana Card + selfie image verification (capture flow)
QOREID_WORKFLOW_ID=your_workflow_id
# Windows only: explicit CA bundle if Guzzle doesn't use php.ini curl.cainfo. Leave empty on Linux.
# QOREID_CAINFO="E:\path\to\cacert.pem"
# Legacy: direct secret as Bearer (used if client_id/secret not set)
# QOREID_SECRET_KEY=your_qoreid_secret_key
